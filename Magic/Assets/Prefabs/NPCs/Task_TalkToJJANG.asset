  - speaker: "\uC548\uB0B4\uC6D0"
    dialogue:
    - "\uC5B4\uC11C \uC640! \uBA54\uD0C0 \uB9C8\uC744\uC758 \uC0C8\uB85C\uC6B4 \uC8FC\uBBFC\uC774
      \uB41C \uAC78 \uD658\uC601\uD574!"
    - "\uB098\uB294 \uB108\uC5D0\uAC8C \uC774\uACF3\uC744 \uC18C\uAC1C\uD574 \uC904
      \uB9C8\uC744 \uC548\uB0B4\uC6D0\uC774\uC57C. \uC6B0\uB9AC \uB9C8\uC744\uC774
      \uCC98\uC74C\uC774\uB2C8?"
    options:
    - optionText: "\uC751, \uCC98\uC74C\uC774\uC57C."
      nextDialogue:
      - speaker: "\uC548\uB0B4\uC6D0"
        dialogue:
        - "\uBA54\uD0C0 \uB9C8\uC744\uC5D0\uC11C\uB294 \uB3C8\uC744 \uBC8C\uACE0
          \uAD00\uB9AC\uD558\uBA70 \uC790\uC0B0\uC744 \uD0A4\uC6B8 \uC218 \uC788\uC5B4.
          \uD0A4\uC6B4 \uC790\uC0B0\uC73C\uB85C \uB2E4\uC591\uD55C \uBB3C\uAC74\uC744
          \uC0B4 \uC218\uB3C4 \uC788\uC9C0."
        - "\uC790\uC0B0\uC744 \uD0A4\uC6B0\uAE30 \uC704\uD574\uC11C\uB294 \uAE08\uC735
          \uC9C0\uC2DD\uC744 \uC313\uB294 \uAC83\uC774 \uB9E4\uC6B0 \uC911\uC694\uD574.
          \uAE08\uC735 \uC9C0\uC2DD\uC774\uB780 \uACBD\uC81C\uC640 \uC790\uC0B0 \uAD00\uB9AC\uC5D0
          \uB300\uD55C \uBAA8\uB4E0 \uC815\uBCF4\uB97C \uC758\uBBF8\uD574. "
        options: []
        currentState: 2
        changedState: 3
        eventNum: {x: 0, y: 0}
      optioneventNum: {x: 0, y: 0}
    - optionText: "\uC544\uB2C8, \uC798 \uC54C\uACE0\uC788\uC5B4."
